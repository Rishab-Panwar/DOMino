# =============================================================================
# DOMino backend configuration. Copy this file to backend/.env and fill in the
# keys for the ONE reasoning provider you want, plus Firecrawl (optional).
#
# Note: Speech-to-text and text-to-speech keys (ElevenLabs, Groq, Deepgram)
# are NOT set here. Enter those in the extension's Settings page.
# =============================================================================

# Which model DOMino uses for reasoning. Pick one provider below and set the
# matching keys. Options:
#   vertex-gemini-flash (default), vertex-gemini-pro    -> Google Vertex AI
#   gemini-flash, gemini-flash-lite                     -> Google AI Studio
#   openrouter-gemini-free, openrouter-deepseek-free, openrouter-claude -> OpenRouter
#   groq-llama-70b, groq-llama                          -> Groq
#   nova-lite, nova-pro, claude-haiku, claude-sonnet    -> AWS Bedrock
DOMINO_MODEL=vertex-gemini-flash

# --- Google Vertex AI (default; first-party Gemini billed to your GCP project) -
# Auth: point GOOGLE_APPLICATION_CREDENTIALS at a service-account JSON, OR run
# `gcloud auth application-default login` and leave it blank.
VERTEX_PROJECT_ID=your-gcp-project-id
VERTEX_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json

# --- Google AI Studio (free Gemini key, no card; rate-limited) ----------------
GEMINI_API_KEY=your-gemini-api-key

# --- OpenRouter (aggregator; free models need no card) ------------------------
# Get a key at openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key

# --- Groq (fast; free tier limits tokens per minute) --------------------------
# Also used as the backend /transcribe STT fallback.
GROQ_API_KEY=your-groq-api-key

# --- AWS Bedrock (Nova / Claude) ----------------------------------------------
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1

# --- Firecrawl (optional; richer page context, page to markdown) --------------
FIRECRAWL_API_KEY=your-firecrawl-api-key

# --- Server -------------------------------------------------------------------
BACKEND_PORT=8000
